{
  "name": "remotion-app",
  "version": "1.0.0",
  "description": "Dean Graziosi style Remotion caption revamp for FEMALE COACH video",
  "main": "index.js",
  "scripts": {
    "captions:sync": "tsx scripts/captions-sync.ts",
    "captions:sync:longform": "tsx scripts/captions-sync.ts --presentation long-form",
    "dev": "vite --configLoader native --port 3010",
    "studio": "remotion studio src/index.ts --port 3011",
    "matte:sync": "tsx scripts/matte-sync.ts",
    "motion-assets:sync": "tsx scripts/motion-assets-sync.ts",
    "motion-assets:sync:authoring": "tsx scripts/motion-assets-authoring-sync.ts",
    "animation:prototype:index": "tsx scripts/animation-prototype-index.ts",
    "pattern-memory:sync": "tsx scripts/pattern-memory-sync.ts",
    "music:sync": "tsx scripts/music-sync.ts",
    "soundfx:sync": "tsx scripts/sound-fx-sync.ts",
    "transition-overlays:sync": "tsx scripts/transition-overlays-sync.ts",
    "showcase:remove-bg": "node scripts/showcase-remove-bg.js",
    "showcase:imports:sync": "tsx scripts/showcase-imports-sync.ts",
    "showcase:sync": "tsx scripts/showcase-assets-sync.ts --publish false",
    "showcase:upload:supabase": "tsx scripts/supabase-bucket-sync.ts --source-dir public/showcase-assets",
    "assets:scan": "tsx scripts/assets-scan.ts",
    "assets:index": "tsx scripts/assets-index.ts",
    "assets:index:full": "tsx scripts/assets-index.ts --full",
    "assets:prefetch:bge-m3": "python scripts/prefetch-bge-m3.py",
    "assets:reindex": "tsx scripts/assets-reindex.ts",
    "assets:test-query": "tsx scripts/assets-test-query.ts",
    "ingest-fonts": "tsx scripts/font-ingest.ts",
    "embed-fonts": "tsx scripts/font-embed.ts",
    "build-font-graph": "tsx scripts/font-build-graph.ts",
    "font-pipeline-all": "tsx scripts/font-pipeline-all.ts",
    "ingest-fonts-to-milvus": "tsx scripts/font-ingest-to-milvus.ts",
    "typography:audit": "npx tsx scripts/typography-audit.ts",
    "typography:graph": "npx tsx scripts/typography-graph.ts",
    "vector:ingest": "tsx scripts/ingest-assets-to-milvus.ts",
    "vector:ingest:dry": "tsx scripts/ingest-assets-to-milvus.ts --dry-run",
    "video:chunk": "node scripts/video-chunk.js",
    "video:ingest": "tsx scripts/captions-sync.ts",
    "video:ingest:longform": "tsx scripts/captions-sync.ts --presentation long-form",
    "compositions": "remotion compositions src/index.ts",
    "preview:web": "vite --configLoader native",
    "preview:web:build": "vite build --configLoader native",
    "preview:web:serve": "vite preview --configLoader native",
    "draft:preview:longform": "tsx scripts/draft-preview-longform.ts",
    "render:master:longform": "tsx scripts/master-render-longform.ts",
    "render": "remotion render src/index.ts FemaleCoachDeanGraziosi out/FEMALE-COACH-dean-graziosi.mp4 --codec=h264 --audio-codec=aac",
    "render:final": "npm run captions:sync && npm run render",
    "nolan:plan": "tsx scripts/nolan-clip-plan.ts",
    "nolan:extract": "tsx scripts/nolan-clip-extract.ts",
    "test": "vitest run --configLoader native --pool threads",
    "test:watch": "vitest --configLoader native --pool threads",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remotion",
    "captions",
    "assemblyai",
    "groq"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@remotion/cli": "^4.0.428",
    "@remotion/google-fonts": "^4.0.428",
    "@remotion/player": "^4.0.428",
    "@zilliz/milvus2-sdk-node": "^2.6.13",
    "dotenv": "^17.3.1",
    "gsap": "^3.14.2",
    "natural": "^8.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.428",
    "sharp": "^0.34.5",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
