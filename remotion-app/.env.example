ASSET_MILVUS_ENABLED=true
MILVUS_ADDRESS=127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_COLLECTION_ASSETS=unified_motion_graphics_assets

ASSET_EMBEDDING_PROVIDER=local-hf
ASSET_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
ASSET_EMBEDDING_DIMENSIONS=384
ASSET_EMBEDDING_BATCH_SIZE=8
ASSET_EMBEDDING_TEXT_MODE=compact
ASSET_EMBEDDING_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LOCAL_EMBEDDING_PYTHON_BIN=python
LOCAL_EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
LOCAL_EMBEDDING_DIMENSIONS=384
LOCAL_EMBEDDING_USE_FP16=false
# Experimental opt-in only:
# BGE_M3_LOCAL_PYTHON_BIN=python
# BGE_M3_LOCAL_MODEL_NAME=BAAI/bge-m3
# BGE_M3_LOCAL_USE_FP16=false

ASSET_REINDEX_MODE=incremental
ASSET_ROOT_DIRS=../STATIC ASSETS|../STRUCTURED ANIMATION|../GSAP STORIES|../GSAP THREE JS ANIMATIONS|../SVG animations|public/motion-assets|public/showcase-assets|public/showcase-source
ASSET_PUBLIC_CACHE_DIR=public/retrieval-assets
ASSET_SCAN_SNAPSHOT_PATH=src/data/unified-asset-documents.generated.json
ASSET_RUNTIME_CATALOG_PATH=src/data/unified-motion-assets.generated.json
ASSET_INDEX_STATE_PATH=src/data/unified-asset-index-state.generated.json
