# ==============================================================================
# GLOBAL PROMETHEUS ENVIRONMENT CONFIGURATION
# This file consolidates all environment variables used by backend and remotion-app.
# Use this for Render deployment and local development synchronization.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SERVER & CORE SETTINGS
# ------------------------------------------------------------------------------
PORT=8000
STORAGE_DIR=./data
MAX_UPLOAD_FILE_SIZE_BYTES=524288000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010,http://localhost:3101,http://127.0.0.1:3101,http://localhost:4101,http://127.0.0.1:4101,http://localhost:5173,http://127.0.0.1:5173
JOB_QUEUE_CONCURRENCY=1

# ------------------------------------------------------------------------------
# 2. AI & LLM PROVIDERS
# ------------------------------------------------------------------------------
ASSEMBLYAI_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1600
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------------------------
# 3. VECTOR DATABASE (MILVUS)
# ------------------------------------------------------------------------------
ASSET_MILVUS_ENABLED=true
MILVUS_ADDRESS=127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=prometheus_creative_assets
MILVUS_COLLECTION_ASSETS=unified_motion_graphics_assets

# ------------------------------------------------------------------------------
# 4. CLOUD STORAGE (CLOUDFLARE R2 / S3 COMPATIBLE)
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOAD_BUCKET=prometheus-uploads
R2_PUBLIC_UPLOADS_BASE=
R2_UPLOAD_URL_EXPIRES_SECONDS=600

# ------------------------------------------------------------------------------
# 5. EMBEDDING SETTINGS (CORE & ASSETS)
# ------------------------------------------------------------------------------
# Providers: openai, local-test, local-hf, bge-m3-local
EMBEDDING_PROVIDER=local-hf
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
EMBEDDING_API_KEY=

ASSET_EMBEDDING_PROVIDER=local-hf
ASSET_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
ASSET_EMBEDDING_DIMENSIONS=384
ASSET_EMBEDDING_BATCH_SIZE=8
ASSET_EMBEDDING_TEXT_MODE=compact
ASSET_EMBEDDING_API_KEY=

# Local Embedding Configuration
LOCAL_EMBEDDING_PYTHON_BIN=python
LOCAL_EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
LOCAL_EMBEDDING_DIMENSIONS=384
LOCAL_EMBEDDING_USE_FP16=false

# BGE-M3 Specific (Experimental)
BGE_M3_LOCAL_PYTHON_BIN=python
BGE_M3_LOCAL_MODEL_NAME=BAAI/bge-m3
BGE_M3_LOCAL_USE_FP16=false

# ------------------------------------------------------------------------------
# 6. FEATURE FLAGS & PREVIEW ENGINE
# ------------------------------------------------------------------------------
# PREVIEW_ENGINE: hyperframes, remotion
PREVIEW_ENGINE=hyperframes
ENABLE_HYPERFRAMES_PREVIEW=true
ENABLE_LEGACY_OVERLAY=false
ENABLE_LIVE_BROWSER_OVERLAY=false
ENABLE_REMOTION_PREVIEW=false
ENABLE_AUDIO_ONLY_PREVIEW=false
ENABLE_DARK_AUDIO_PREVIEW=false
ENABLE_BLACK_PREVIEW_BACKGROUND=false
ENABLE_MANIFEST_TYPOGRAPHY=true
ENABLE_FONT_GRAPH=true
ENABLE_MILVUS_ANIMATION_RETRIEVAL=true
ENABLE_SERVER_RENDERED_PREVIEW=true
ENABLE_PREVIEW_DIAGNOSTICS=true
ENABLE_PREVIEW_PIPELINE_TRACE=true

# ------------------------------------------------------------------------------
# 7. GOD (GENERATIVE ORCHESTRATION & DESIGN) PROVIDER
# ------------------------------------------------------------------------------
GOD_PROVIDER_KIND=local-template
GOD_PROVIDER_ENDPOINT=
GOD_PROVIDER_API_KEY=
GOD_PROVIDER_MODEL=
GOD_PROVIDER_TIMEOUT_MS=45000
GOD_COLLECTION_DIR=../remotion-app/public/motion-assets/god
GOD_COLLECTION_MANIFEST_PATH=../remotion-app/src/data/god-assets.generated.json
GOD_REVIEW_DIR=./data/god

# GOD Scoring Thresholds
GOD_MIN_TECHNICAL_SCORE=0.78
GOD_MIN_COMPOSITING_SCORE=0.82
GOD_MIN_AESTHETIC_SCORE=0.74
GOD_MIN_STYLE_SCORE=0.7
GOD_MIN_MOTION_SCORE=0.68
GOD_MIN_REUSE_SCORE=0.66
GOD_MIN_OVERALL_SCORE=0.75
GOD_MAX_BRIEF_SIMILARITY=0.88
GOD_AUTO_PROMOTE=false

# ------------------------------------------------------------------------------
# 8. FONT INTELLIGENCE & TYPOGRAPHY
# ------------------------------------------------------------------------------
FONT_INTELLIGENCE_SOURCE_ZIP_DIR=../FONTS
FONT_INTELLIGENCE_WORKSPACE_DIR=../font-intelligence
FONT_INTELLIGENCE_PYTHON_BIN=python
FONT_INTELLIGENCE_METADATA_SCRIPT=scripts/font_metadata_probe.py
FONT_INTELLIGENCE_EMBEDDING_PROVIDER=local-hf
FONT_INTELLIGENCE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FONT_INTELLIGENCE_EMBEDDING_DIMENSIONS=384
FONT_INTELLIGENCE_EMBEDDING_BATCH_SIZE=8
FONT_INTELLIGENCE_MILVUS_COLLECTION=prometheus_typography_fonts
FONT_INTELLIGENCE_TOP_MATCHES_PER_FONT=12
FONT_COMBO_ID=

# ------------------------------------------------------------------------------
# 9. ASSET INDEXING & CATALOG
# ------------------------------------------------------------------------------
ASSET_REINDEX_MODE=incremental
ASSET_ROOT_DIRS=../STATIC ASSETS|../STRUCTURED ANIMATION|../GSAP STORIES|../GSAP THREE JS ANIMATIONS|../SVG animations|public/motion-assets|public/showcase-assets|public/showcase-source
ASSET_PUBLIC_CACHE_DIR=public/retrieval-assets
ASSET_SCAN_SNAPSHOT_PATH=src/data/unified-asset-documents.generated.json
ASSET_RUNTIME_CATALOG_PATH=src/data/unified-motion-assets.generated.json
ASSET_INDEX_STATE_PATH=src/data/unified-asset-index-state.generated.json
ASSET_BRAIN_ENABLED=false

# ------------------------------------------------------------------------------
# 10. PATTERN MEMORY (EXPERIMENTAL)
# ------------------------------------------------------------------------------
PATTERN_MEMORY_SNAPSHOT_PATH=
PATTERN_MEMORY_ROOT_DIR=
PATTERN_MEMORY_MIRROR_PATH=
PATTERN_MEMORY_LEDGER_PATH=
PATTERN_MEMORY_INDEX_PATH=

# ------------------------------------------------------------------------------
# 11. FRONTEND / CLIENT SETTINGS
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=
DISPLAY_GOD_PREVIEW=
VITE_DISPLAY_GOD_PREVIEW=
STRUCTURED_ANIMATION_ROOT=
ANIMATION_PROTOTYPE_ROOT=

# ------------------------------------------------------------------------------
# 12. SYSTEM & RUNTIME (PYTHON/HUGGINGFACE)
# ------------------------------------------------------------------------------
PYTHONUTF8=1
TOKENIZERS_PARALLELISM=false
HF_HUB_DISABLE_XET=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1
